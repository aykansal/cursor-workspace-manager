{
  "name": "cursor-workspace-manager",
  "description": "Desktop app to inspect Cursor IDE workspaces, explore AI chat history, analyze SQLite data, and transfer conversations across projects.",
  "homepage": "https://github.com/aykansal/cursor-workspace-manager",
  "repository": {
    "type": "git",
    "url": "https://github.com/aykansal/cursor-workspace-manager.git"
  },
  "bugs": {
    "url": "https://github.com/aykansal/cursor-workspace-manager/issues"
  },
  "keywords": [
    "cursor",
    "cursor ide",
    "cursor ai",
    "workspace manager",
    "ai chat viewer",
    "sqlite viewer",
    "developer tools",
    "electron app",
    "productivity",
    "ai agents",
    "skills",
    "harness",
    "agents",
    "ai"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "stop:prod": "cmd /c taskkill /IM \"Cursor Workspace Manager.exe\" /F >nul 2>&1 || exit /b 0",
    "rebuild:prod": "pnpm stop:prod && pnpm build",
    "start:prod": "cmd /c start \"\" \"dist\\win-unpacked\\Cursor Workspace Manager.exe\"",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "dist": "npm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "lucide-react": "^1.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "electron": "^41.0.4",
    "electron-builder": "^25.1.8",
    "eslint": "^9.23.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.ayush.cursorworkspacemanager",
    "productName": "Cursor Workspace Manager",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*"
    ],
    "asar": true
  },
  "main": "dist-electron/main.js"
}